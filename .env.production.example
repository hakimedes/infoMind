INFOMIND_PORT=3456
INFOMIND_DB_PATH=/app/data/infomind.db

# Keep this stable across migrations. If you already used a custom
# INFOMIND_SECRET locally, copy the same value to the server before start.
INFOMIND_SECRET=replace-with-a-long-random-secret

# Optional public base URL used by agents or reverse proxy docs.
INFOMIND_PUBLIC_URL=https://infomind.example.com
